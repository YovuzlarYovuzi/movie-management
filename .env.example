# Example environment variables for movie-management
# Copy to .env and edit values before running docker-compose.full.yml or local scripts

SECRET_KEY=replace-this-with-a-secret
DEBUG=True

# Postgres (DATABASE_URL example)
DATABASE_URL=postgres://postgres:postgres@db:5432/movie_db

# Redis
REDIS_URL=redis://redis:6379/0

# RabbitMQ for Celery broker
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Site feature flag
GAME_ENABLED=False

# Optional: allowed hosts comma separated
ALLOWED_HOSTS=localhost,127.0.0.1
