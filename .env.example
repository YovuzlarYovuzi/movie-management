# Example environment variables for movie-management
# Copy to .env and edit values before running docker-compose.full.yml or local scripts

SECRET_KEY=replace-this-with-a-secret
DEBUG=True

# Postgres (DATABASE_URL example)
DATABASE_URL=postgres://postgres:postgres@db:5432/movie_db

# Redis
REDIS_URL=redis://redis:6379/0

# RabbitMQ for Celery broker
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Site feature flag
GAME_ENABLED=False

# Optional: allowed hosts comma separated
ALLOWED_HOSTS=localhost,127.0.0.1

# --- GitHub Actions / Deployment Secrets (placeholders only) ---
# These are examples of the Secrets you should add in GitHub repository
# Settings → Secrets → Actions. NEVER put real secret values into the
# repository; keep them in GitHub Secrets or your deployment provider.
# Example values (replace in GitHub Secrets, do NOT commit real secrets):
# SSH (for `.github/workflows/deploy-ssh.yml`)
SSH_HOST=example.com
SSH_USER=deploy
SSH_PATH=/var/www/movie-management

# Fly.io (if using Fly deploy)
FLY_API_TOKEN=__YOUR_FLY_API_TOKEN__

# External services
DATABASE_URL=postgres://user:password@host:5432/dbname
REDIS_URL=redis://:password@redis-host:6379/0
CELERY_BROKER_URL=amqp://user:password@rabbitmq-host:5672//
CELERY_RESULT_BACKEND=redis://:password@redis-host:6379/1

# App secret (example placeholder)
SECRET_KEY=replace-this-with-a-secret
